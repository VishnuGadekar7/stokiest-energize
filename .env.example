RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
HR_EMAIL=hr@energizepharma.com
MONGODB_URI=mongodb+srv://user:pass@cluster/energize
PORT=3000

# --- Puppeteer Chrome Path ---
# Leave blank to auto-detect Chrome on Windows (Program Files search).
# On Render.com production, set this to:
#   PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
#
# On macOS, set to:
#   PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#
# On Windows (if auto-detect fails), set to:
#   PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
PUPPETEER_EXECUTABLE_PATH=
